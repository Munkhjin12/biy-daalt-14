      "name": "Users",
      "item": [
        {
          "name": "GET User by id — Хэрэглэгч авах",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('User schema зөв', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('id');",
                  "  pm.expect(d).to.have.property('name');",
                  "  pm.expect(d).to.have.property('email');",
                  "  pm.expect(d).to.have.property('username');",
                  "});",
                  "pm.test('Email формат зөв (бизнес дүрэм)', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.email).to.be.a('string').and.match(/@/);",
                  "});",
                  "pm.test('id нь тоо', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.id).to.be.a('number');",
                  "});",
                  "pm.test('Content-Type JSON байна', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
