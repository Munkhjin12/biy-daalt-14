        {
          "name": "POST create — Шинэ нийтлэл үүсгэх",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Pre-request: random title үүсгэх",
                  "const randomNum = Math.floor(Math.random() * 1000);",
                  "pm.environment.set('randomTitle', 'Test Post ' + randomNum);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Шинэ id буцаасан', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('id');",
                  "  pm.expect(d.id).to.be.a('number');",
                  "  pm.environment.set('newPostId', d.id);",
                  "});",
                  "pm.test('Response < 1s', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test('Title хадгалагдсан', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('title');",
                  "  pm.expect(d.title).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{randomTitle}}\",\n  \"body\": \"Энэ бол Newman CI тестийн нийтлэл\",\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
