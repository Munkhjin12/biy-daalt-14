      "item": [
        {
          "name": "Happy GET — Бүх нийтлэл авах",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Pre-request: хүсэлт явуулах цагийн тэмдэглэл хадгалах",
                  "pm.environment.set('requestTime', new Date().toISOString());"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response < 1s\", () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "// Chain",
                  "const data = pm.response.json();",
                  "pm.environment.set(\"postId\", data[0].id);",
                  "pm.environment.set(\"userId\", data[0].userId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts"
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET by id — Нийтлэл id-аар авах",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response < 1s', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test('Post schema зөв', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('id');",
                  "  pm.expect(d).to.have.property('title');",
                  "  pm.expect(d).to.have.property('body');",
                  "  pm.expect(d.title).to.be.a('string').and.have.length.above(0);",
                  "});"
                ],
